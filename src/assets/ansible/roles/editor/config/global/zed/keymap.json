[
  {
    "context": "ProjectPanel",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-r": "workspace::CopyRelativePath",
      "ctrl-a": "workspace::CopyPath"
    }
  },
  {
    "context": "Workspace",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-w": "pane::CloseAllItems",
      "cmd-i": "agent::ToggleFocus"
    }
  },
  {
    "context": "Editor && mode == full",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-i": "agent::ToggleFocus"
    }
  },
  {
    "context": "Terminal",
    "use_key_equivalents": true,
    "bindings": {
      "shift-enter": [
        "terminal::SendText",
        "\n"
      ],
      "ctrl-`": "workspace::NewTerminal",
      "alt-cmd-\\": "pane::SplitRight",
      "alt-cmd-¥": "pane::SplitRight",
      "cmd-¥": "pane::SplitRight",
      "cmd-\\": "pane::SplitRight",
      "cmd-i": "agent::ToggleFocus"
    }
  }
]
